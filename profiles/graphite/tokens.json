{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "DEMO profile — 'Graphite', an invented developer-tooling brand in the RESTRAINT register: near-black, no brand color, silvery institutional accent, neutral sans headlines, monospace labels. The counterpart to Northwind (warmth) — together the two demos show both halves of the meta-thesis. DTCG format.",
  "$extensions": {
    "kit.profile": "graphite",
    "kit.register": "restraint"
  },
  "color": {
    "$type": "color",
    "bg":             { "$value": "#0B0E14", "$description": "Near-black — default background." },
    "bg-card":        { "$value": "#141921", "$description": "Card / panel." },
    "bg-dark":        { "$value": "#070A0F", "$description": "Deepest surface (header/footer)." },
    "text-primary":   { "$value": "#FFFFFF", "$description": "Headlines, strong text." },
    "text-body":      { "$value": "#C5CCD6", "$description": "Body copy." },
    "text-secondary": { "$value": "#949DAD", "$description": "Secondary copy, metadata." },
    "text-dim":       { "$value": "#6C7585", "$description": "Dim — mono labels, footer." },
    "text-on-dark":   { "$value": "#C5CCD6", "$description": "Body on the deepest surface (= dark mode default)." },
    "border":         { "$value": "#242C39", "$description": "Hairline borders, dividers." },
    "accent":         { "$value": "#AEB9CC", "$description": "Silvery — institutional accent. No brand color." },
    "accent-2":       { "$value": "#7E8AA0", "$description": "Dimmer silvery for secondary marks." },
    "accent-on-dark": { "$value": "#AEB9CC", "$description": "Same silvery on the deepest surface." },
    "emphasis":       { "$value": "#B5524A", "$description": "Decisive figures only. One per section max." }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "serif": { "$value": ["Inter", "-apple-system", "sans-serif"], "$description": "Restraint uses no serif — falls back to the sans." },
    "sans":  { "$value": ["Inter", "-apple-system", "Segoe UI", "Arial", "sans-serif"], "$description": "Headlines, body, UI — everything." },
    "mono":  { "$value": ["JetBrains Mono", "Menlo", "monospace"], "$description": "Labels, metadata, code." }
  },
  "ratio": {
    "$type": "number",
    "bg-pct":     { "$value": 70 },
    "card-pct":   { "$value": 20 },
    "accent-pct": { "$value": 10 }
  },
  "lint": {
    "$type": "other",
    "$description": "Constants consumed by lint.mjs.",
    "company-name":  { "$value": "Graphite" },
    "url":           { "$value": "graphite.example" },
    "contact":       { "$value": "hello@graphite.example" },
    "max-accents":   { "$value": 1, "$description": "Silvery only — restraint register uses no brand color." },
    "forbidden-bg":  { "$value": [], "$description": "Dark mode allows pure black/white." },
    "forbidden-text":{ "$value": [] },
    "foreign-names": { "$value": ["Northwind"], "$description": "Flag the other demo brand if it leaks into a Graphite artifact." }
  }
}
