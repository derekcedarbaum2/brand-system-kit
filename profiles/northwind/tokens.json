{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "DEMO profile — 'Northwind', an invented calm-SaaS brand (paper + teal). Ships so the pipeline runs end-to-end out of the box. Replace with your own via the /brand-init skill. DTCG format.",
  "$extensions": {
    "kit.profile": "northwind",
    "kit.register": "warmth"
  },
  "color": {
    "$type": "color",
    "bg":             { "$value": "#FBFAF7", "$description": "Paper — page background. Warm off-white, not pure #FFFFFF." },
    "bg-doc":         { "$value": "#FBFAF7", "$description": "Paper — the document-mode surface emphasis is contrast-checked against." },
    "bg-card":        { "$value": "#F0EEE8", "$description": "Card / panel background." },
    "bg-dark":        { "$value": "#14201F", "$description": "Dark accent panel background." },
    "text-primary":   { "$value": "#161A19", "$description": "Ink — headlines, strong text." },
    "text-body":      { "$value": "#353B3A", "$description": "Body paragraphs." },
    "text-secondary": { "$value": "#5C6463", "$description": "Secondary copy, metadata." },
    "text-dim":       { "$value": "#6E7574", "$description": "Dim — small labels, footer." },
    "text-on-dark":   { "$value": "#E6E9E7", "$description": "Body text on dark panels." },
    "border":         { "$value": "#E3E0D8", "$description": "Hairline borders, dividers, rules." },
    "accent":         { "$value": "#1F6E7A", "$description": "Teal — primary accent, links." },
    "accent-2":       { "$value": "#3E5C8A", "$description": "Slate — secondary accent, data viz." },
    "accent-on-dark": { "$value": "#5FB3BF", "$description": "Brighter teal for dark panels." },
    "emphasis":       { "$value": "#9A2D2D", "$description": "Decisive figures only (document mode). One per section max." }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "serif": { "$value": ["Source Serif 4", "Georgia", "serif"], "$description": "Headlines, pull quotes." },
    "sans":  { "$value": ["Inter", "-apple-system", "Segoe UI", "Arial", "sans-serif"], "$description": "Body, UI." },
    "mono":  { "$value": ["JetBrains Mono", "Menlo", "monospace"], "$description": "Labels, metadata, code." }
  },
  "ratio": {
    "$type": "number",
    "bg-pct":     { "$value": 80 },
    "card-pct":   { "$value": 15 },
    "accent-pct": { "$value": 5 }
  },
  "lint": {
    "$type": "other",
    "$description": "Constants consumed by lint.mjs.",
    "company-name":  { "$value": "Northwind" },
    "url":           { "$value": "northwind.example" },
    "contact":       { "$value": "hello@northwind.example" },
    "max-accents":   { "$value": 2 },
    "forbidden-bg":  { "$value": ["#FFFFFF", "#ffffff", "#FFF", "#fff"], "$description": "Paper, never pure white." },
    "forbidden-text":{ "$value": ["#000000", "#000"], "$description": "Ink, never pure black." },
    "foreign-names": { "$value": ["Graphite"], "$description": "Names of your OTHER profiles — flagged if they leak into a Northwind artifact." }
  }
}
